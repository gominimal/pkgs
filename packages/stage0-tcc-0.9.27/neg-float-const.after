	if (is_float(t)) {
	    /* [R3 amd64 fix 2026-06-26] If the operand is already a constant, negate it in place.
	       The IEEE subtract(-0,x) path below is MISCOMPILED by the bootstrap tcc-0.9.26 on amd64
	       (the constant fold is dropped, so a negated float literal in a static initializer is
	       wrongly rejected as "initializer element is not constant" -> SIGSEGV). A direct negate
	       of the constant is generated correctly and is value-identical for finite operands.
	       gcc-built tcc-0.9.27 does not need this; our mes-chain-built one does. */
	    if ((vtop->r & (VT_VALMASK | VT_LVAL | VT_SYM)) == VT_CONST) {
	        if (t == VT_FLOAT) vtop->c.f = -vtop->c.f;
	        else if (t == VT_DOUBLE) vtop->c.d = -vtop->c.d;
	        else vtop->c.ld = -vtop->c.ld;
	        break;
	    }
