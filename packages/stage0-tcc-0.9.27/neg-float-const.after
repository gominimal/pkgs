	    }
	    vpush(&vtop->type);
	    if (t == VT_FLOAT)
	        vtop->c.i = 0x80000000U;            /* -0.0f bits */
	    else if (t == VT_DOUBLE)
	        vtop->c.i = (uint64_t)1 << 63;      /* -0.0  bits */
