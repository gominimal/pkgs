amd64-only: tcc-0.9.27 segfaults ASSEMBLING crt_arch.h's `lea _DYNAMIC(%rip),%rsi` (a
weak+hidden symbol via a RIP-relative reloc). Every -f/-W flag probe passed; only this
asm crashes it. For the STATIC crt (crt1.c) _start_c(p) uses only rdi (the stack ptr) —
rsi/_DYNAMIC is vestigial (it feeds the dynamic linker, used only by Scrt1/rcrt1, which
we already skip). Replace the _DYNAMIC lea with `xor %esi,%esi` (rsi=0). i386 never hit
this (no %rip); live-bootstrap builds --host=i386.
--- musl-1.1.24/arch/x86_64/crt_arch.h
+++ musl-1.1.24/arch/x86_64/crt_arch.h
@@ -4,9 +4,7 @@
 START ": \n"
 "	xor %rbp,%rbp \n"
 "	mov %rsp,%rdi \n"
-".weak _DYNAMIC \n"
-".hidden _DYNAMIC \n"
-"	lea _DYNAMIC(%rip),%rsi \n"
+"	xor %esi,%esi \n"
 "	andq $-16,%rsp \n"
 "	call " START "_c \n"
 );
