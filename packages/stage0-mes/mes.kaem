/usr/bin/cp include/linux/syscall.h /build/output/usr/include/linux/syscall.h
/usr/bin/cp include/linux/x86_64/syscall.h /build/output/usr/include/linux/x86_64/syscall.h

/usr/bin/cp include/mes/builtins.h /build/output/usr/include/mes/builtins.h
/usr/bin/cp include/mes/cc.h /build/output/usr/include/mes/cc.h
# pass1.kaem: `catm ${INCDIR}/mes/config.h` -> create an EMPTY installed config.h (1 arg = 0 inputs).
/usr/bin/catm /build/output/usr/include/mes/config.h
/usr/bin/cp include/mes/constants.h /build/output/usr/include/mes/constants.h
/usr/bin/cp include/mes/lib.h /build/output/usr/include/mes/lib.h
/usr/bin/cp include/mes/lib-cc.h /build/output/usr/include/mes/lib-cc.h
