mescc libc.c
/usr/bin/catm /build/mes-0.27.1/lib/x86_64-mes/libc.a /build/mes-0.27.1/lib/x86_64-mes/libc-mini.a libc.o
/usr/bin/catm /build/mes-0.27.1/lib/x86_64-mes/libc.s /build/mes-0.27.1/lib/x86_64-mes/libc-mini.s libc.s

# libc+tcc.a
/usr/bin/catm libc+tcc.c \
