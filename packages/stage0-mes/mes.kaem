mescc libc+tcc.c
/usr/bin/catm /build/mes-0.27.1/lib/x86_64-mes/libc+tcc.a /build/mes-0.27.1/lib/x86_64-mes/libc.a libc+tcc.o
/usr/bin/catm /build/mes-0.27.1/lib/x86_64-mes/libc+tcc.s /build/mes-0.27.1/lib/x86_64-mes/libc.s libc+tcc.s

############################################################
# Install into the staging tree (pass1.kaem lines 287-374).#
# ${PREFIX} -> /build/output/usr ; ${INCDIR} -> …/include  #
############################################################
# Install libraries
/usr/bin/cp /build/mes-0.27.1/lib/x86_64-mes/libc.a /build/output/usr/lib/x86_64-mes/
/usr/bin/cp /build/mes-0.27.1/lib/x86_64-mes/libc+tcc.a /build/output/usr/lib/x86_64-mes/
/usr/bin/cp /build/mes-0.27.1/lib/x86_64-mes/libmescc.a /build/output/usr/lib/x86_64-mes/
/usr/bin/cp /build/mes-0.27.1/lib/x86_64-mes/libc.s /build/output/usr/lib/x86_64-mes/
/usr/bin/cp /build/mes-0.27.1/lib/x86_64-mes/libc+tcc.s /build/output/usr/lib/x86_64-mes/
/usr/bin/cp /build/mes-0.27.1/lib/x86_64-mes/libmescc.s /build/output/usr/lib/x86_64-mes/
/usr/bin/cp /build/mes-0.27.1/lib/x86_64-mes/x86_64.M1 /build/output/usr/lib/x86_64-mes/
/usr/bin/cp /build/mes-0.27.1/lib/x86_64-mes/crt1.o /build/output/usr/lib/x86_64-mes/
/usr/bin/cp /build/mes-0.27.1/lib/x86_64-mes/crt1.s /build/output/usr/lib/x86_64-mes/
/usr/bin/cp /build/mes-0.27.1/lib/linux/x86_64-mes/elf64-footer-single-main.hex2 /build/output/usr/lib/linux/x86_64-mes/
/usr/bin/cp /build/mes-0.27.1/lib/linux/x86_64-mes/elf64-header.hex2 /build/output/usr/lib/linux/x86_64-mes/

# Install headers (top-level)
/usr/bin/cp include/alloca.h /build/output/usr/include/alloca.h
/usr/bin/cp include/argz.h /build/output/usr/include/argz.h
/usr/bin/cp include/ar.h /build/output/usr/include/ar.h
