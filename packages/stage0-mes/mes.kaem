/usr/bin/cp include/mes/mes.h /build/output/usr/include/mes/mes.h
/usr/bin/cp include/mes/symbols.h /build/output/usr/include/mes/symbols.h

/usr/bin/cp include/sys/cdefs.h /build/output/usr/include/sys/cdefs.h
/usr/bin/cp include/sys/dir.h /build/output/usr/include/sys/dir.h
/usr/bin/cp include/sys/file.h /build/output/usr/include/sys/file.h
