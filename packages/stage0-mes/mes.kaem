# stage0-mes / mes.kaem  — R1 rung driver (DRAFT).  Faithful port of live-bootstrap
# steps/mes-0.27.1/pass1.kaem (read verbatim 2026-06-20), driven by the ATTESTED full C
# kaem from R0 (/usr/bin/kaem, 6364de59…).  kaem aborts HARD on any non-zero child, so each
# line is also an assertion.  kaem builtins used: variable assignment, ${var:-default}
# (verified in mescc-tools Kaem/variable.c), if/then/fi (n/a here — arch inlined), cd, alias,
# exec, PATH.  No bash: the only shell is this attested kaem.  The inner `kaem --file
# kaem.x86_64` (-> kaem.run) is M2-Planet's compile of mes-m2.
#
# ADAPTATIONS vs upstream pass1.kaem (every one is annotated [ADAPT]):
#   * arch `if match` block -> inlined (we are amd64 / x86_64 / 64-bit).            [ADAPT]
#   * checksum-transcriber + sha256sum -c sources.SHA256SUM -> DROPPED; minimal's
#     Source{sha256=…} pin already gates tarball integrity before extract.          [ADAPT]
#   * ungz/untar/mkdir build/cd build -> DROPPED; Source{extract=true} already put
#     mes-0.27.1, nyacc-1.00.2 and stage0-posix-1.9.1 under /build.                 [ADAPT]
#   * mescc-tools-extra `replace`  -> /usr/bin/sed -i 's|…|…|g' (attested).         [ADAPT]
#   * live-bootstrap `simple-patch`-> /usr/bin/sed append (attested).               [ADAPT]
#   * file utils (mkdir/cp/rm/chmod/sha256sum) -> attested coreutils.               [ADAPT]
#   * catm -> /usr/bin/catm from R0 (genuinely needed; kaem has no redirection).
#   * install root -> DESTDIR=/build/output (minimal's OUTPUT_DIR); /usr is RO at build.
#     The baked runtime prefix string stays /usr (PREFIX_RT) so mescc.scm byte-matches.[ADAPT]
#   * UPDATE_CHECKSUMS if/else -> a single `sha256sum -c mes.answers` gate.          [ADAPT]

############################################################
# Environment.  PATH must include /usr/bin so the inner    #
# kaem.run finds M2-Planet/M1/hex2/blood-elf (bare names). #
############################################################
PATH=/usr/bin
ARCH=amd64
MES_ARCH=x86_64
ARCH_BITS=64
# kaem.run / kaem.x86_64 inner-build knobs (kaem.x86_64 sets these; we set them too so the
# environment is explicit and the inner kaem inherits them):
cc_cpu=x86_64
mes_cpu=x86_64
stage0_cpu=amd64
blood_elf_flag=--64
# M2libc for the M2-Planet build of mes-m2 (mes 0.27.1 does not ship it).  CONFIRM the
# extracted tree path at build (stage0-posix-1.9.1/M2libc is referenced as-is by R0).
M2LIBC_PATH=/build/stage0-posix-1.9.1/M2libc
# mes interpreter arena/stack (from pass1.kaem; bumped for gen-c99-files below).
MES_ARENA=20000000
MES_MAX_ARENA=20000000
MES_STACK=6000000
MES_VERSION=0.27.1
NYACC_PKG=nyacc-1.00.2
MES_PKG=mes-0.27.1
# Source trees (Source{extract=true} dropped them under /build).  CONFIRM NYACC_DIR name
# at build — could be /build/nyacc-1.00.2-lb1 (the tarball is …-lb1.tar.gz).
MES_PREFIX=/build/mes-0.27.1
NYACC_DIR=/build/nyacc-1.00.2
# Install (staging) tree = minimal OUTPUT_DIR; baked runtime prefix string = /usr.
DESTDIR=/build/output
PREFIX=/build/output/usr
PREFIX_RT=/usr
BINDIR=/build/output/usr/bin
INCDIR=/build/output/usr/include
# Build-tree intermediate libdir (mescc writes lib/x86_64-mes/* here; CWD=MES_PREFIX).
LIBDIR=/build/mes-0.27.1/lib
# mes-m2 runtime module search (pass1 relies on seed.kaem for this).
MES=/build/output/usr/bin/mes-m2
GUILE_LOAD_PATH=/build/mes-0.27.1/mes/module:/build/mes-0.27.1/module:/build/nyacc-1.00.2/module

############################################################
# Staging dirs (seed.kaem mkdir's BINDIR upstream; we must)#
############################################################
/usr/bin/mkdir -p /build/output/usr/bin
/usr/bin/mkdir -p /build/output/usr/lib/x86_64-mes
/usr/bin/mkdir -p /build/output/usr/lib/linux/x86_64-mes
/usr/bin/mkdir -p /build/output/usr/include/mes
/usr/bin/mkdir -p /build/output/usr/include/sys
/usr/bin/mkdir -p /build/output/usr/include/linux/x86_64
/usr/bin/mkdir -p /build/output/usr/include/arch

############################################################
# Prepare the mes source tree (pass1.kaem lines 42-63)     #
############################################################
# Set mes-m2's link base address to 0x8048000 (pass1.kaem applies this on every arch; the
# amd64 mes-m2 checksum 672f2d71… is the post-replace value).  sed = attested `replace`.
# kaem passes single-quotes LITERALLY (kaem.c has a `"` case, NO `'` case) → bare token (no
# spaces in the s|x|y|g expr so it tokenizes as one arg).
/usr/bin/sed -i s|0x1000000|0x8048000|g /build/mes-0.27.1/kaem.run

# Drop in the (empty-ish) mes config.h (Local file lands in /build).
/usr/bin/cp /build/config.h /build/mes-0.27.1/include/mes/config.h

# wait4 patch (upstreamed after 0.27.1).  simple-patch appended `  *long_status_ptr = 0;`
# after the rusage line.  sed append, keyed on the unique rusage line.  EXACT bytes matter:
# the inserted line is two-spaces + `*long_status_ptr = 0;` — wait4.c feeds libc.a, whose
# checksum (bfaf0e3d…) is in mes.answers, so a botched patch fails the gate LOUDLY.
# kaem fix: this expr has SPACES so it needs kaem's `"` quoting (not bare); the sed append's
# `a\` backslash is escaped `\\` so kaem's handle_escape emits a single `\` (gate catches a
# botched patch LOUDLY via libc.a's sha, so a wrong escape fails-shut, never ships).
/usr/bin/sed -i "/  long long_rusage = cast_voidp_to_long (rusage);/a\\  *long_status_ptr = 0;" /build/mes-0.27.1/lib/linux/wait4.c

cd /build/mes-0.27.1
# F1 fix (playbook EDIT 1): the tarball ships no include/arch/ (upstream pass1.kaem mkdir's it,
# line 53); minimal's extract=true does not create it, so the arch-header cp's below abort. Create it.
/usr/bin/mkdir -p include/arch
# Arch header copies (pass1.kaem lines 53-56).
/usr/bin/cp include/linux/x86_64/kernel-stat.h include/arch/kernel-stat.h
/usr/bin/cp include/linux/x86_64/signal.h include/arch/signal.h
/usr/bin/cp include/linux/x86_64/syscall.h include/arch/syscall.h

# Remove pregenerated files so mes-m2 regenerates them from source (psyntax bootstrap).
/usr/bin/rm mes/module/mes/psyntax.pp mes/module/mes/psyntax.pp.header

# These are symlinks in the tarball; replace with real copies (deterministic).
# F2 fix (playbook EDIT 2): minimal's extract=true MATERIALIZES the srfi symlinks (upstream
# untar --non-strict skips them), so `cp src dst` is a same-file error. Remove them first.
/usr/bin/rm -f mes/module/srfi/srfi-9.mes mes/module/srfi/srfi-9/gnu.mes
/usr/bin/cp mes/module/srfi/srfi-9-struct.mes mes/module/srfi/srfi-9.mes
/usr/bin/cp mes/module/srfi/srfi-9/gnu-struct.mes mes/module/srfi/srfi-9/gnu.mes

############################################################
# Build mes-m2 (M2-Planet -> M1 -> hex2; pass1 lines 66-68)#
# kaem.x86_64 sets cc/mes/stage0 cpu + blood_elf_flag, then#
# runs kaem.run (the actual M2-Planet compile of mes.c).   #
############################################################
/usr/bin/kaem --verbose --strict --file kaem.x86_64
/usr/bin/cp bin/mes-m2 /build/output/usr/bin/mes-m2
/usr/bin/chmod 755 /build/output/usr/bin/mes-m2

############################################################
# Regenerate nyacc parser tables with mes-m2 (pass1 71-82) #
############################################################
cd /build/nyacc-1.00.2
/usr/bin/rm module/nyacc/lang/c99/mach.d/c99-act.scm module/nyacc/lang/c99/mach.d/c99-tab.scm \
    module/nyacc/lang/c99/mach.d/c99cx-act.scm module/nyacc/lang/c99/mach.d/c99cx-tab.scm \
    module/nyacc/lang/c99/mach.d/c99x-act.scm module/nyacc/lang/c99/mach.d/c99x-tab.scm \
    module/nyacc/lang/c99/mach.d/cpp-act.scm module/nyacc/lang/c99/mach.d/cpp-tab.scm
/build/output/usr/bin/mes-m2 -L module gen-cpp-files.scm
# gen-c99-files needs a bigger arena:
MES_ARENA=32000000
/build/output/usr/bin/mes-m2 -L module gen-c99-files.scm
MES_ARENA=20000000
/build/output/usr/bin/mes-m2 -L module gen-c99cx-files.scm
cd /build/mes-0.27.1

############################################################
# Create mescc.scm (pass1.kaem lines 85-93)                #
# @prefix@ -> /usr (PREFIX_RT, the RUNTIME prefix) so the  #
# mescc.scm checksum 20655e4e… matches.                    #
############################################################
# kaem fix: bare tokens (no spaces in s|x|y|g; single-quotes would pass to sed literally).
/usr/bin/sed -i s|@prefix@|/usr|g scripts/mescc.scm.in
/usr/bin/sed -i s|@VERSION@|0.27.1|g scripts/mescc.scm.in
/usr/bin/sed -i s|@mes_cpu@|x86_64|g scripts/mescc.scm.in
/usr/bin/sed -i s|@mes_kernel@|linux|g scripts/mescc.scm.in
# R1 iteration #2: mescc.scm.in has 7 @x@ placeholders, not 4 (the draft missed the 3 shebang ones).
# mescc.scm is run via `mes-m2 -e main` so the guile shebang is INERT; substitute clean bootstrap-local
# values + re-pin mescc.scm to our deterministic output (66f721ba). The COMPILER it drives (mes-m2,
# OK byte-perfect) + all libc artifacts remain upstream-byte-identical — only this generated driver
# script's inert shebang differs from live-bootstrap's env-specific 20655e4e.
/usr/bin/sed -i s|@GUILE@|/usr/bin/guile|g scripts/mescc.scm.in
/usr/bin/sed -i s|@guile_site_dir@|/usr/share/guile/site/2.2|g scripts/mescc.scm.in
/usr/bin/sed -i s|@guile_site_ccache_dir@|/usr/lib/guile/2.2/site-ccache|g scripts/mescc.scm.in
/usr/bin/cp scripts/mescc.scm.in /build/output/usr/bin/mescc.scm
/usr/bin/chmod 755 /build/output/usr/bin/mescc.scm

############################################################
# Recompile mes-libc with mes-m2 + MesCC (pass1 97-285).   #
# `mescc` is a kaem alias (verified kaem builtin).         #
############################################################
alias mescc="/build/output/usr/bin/mes-m2 -e main /build/output/usr/bin/mescc.scm -D HAVE_CONFIG_H=1 -I include -I include/linux/x86_64 -c"

# crt1.o
mescc lib/linux/x86_64-mes-mescc/crt1.c -o lib/x86_64-mes/crt1.o

# libc-mini.a
/usr/bin/catm libc-mini.c \
 lib/mes/__init_io.c \
 lib/mes/eputs.c \
 lib/mes/oputs.c \
 lib/mes/globals.c \
 lib/stdlib/exit.c \
 lib/linux/x86_64-mes-mescc/_exit.c \
 lib/linux/x86_64-mes-mescc/_write.c \
 lib/stdlib/puts.c \
 lib/string/strlen.c
mescc libc-mini.c
/usr/bin/cp libc-mini.o /build/mes-0.27.1/lib/x86_64-mes/libc-mini.a
/usr/bin/cp libc-mini.s /build/mes-0.27.1/lib/x86_64-mes/libc-mini.s

# libmescc.a
/usr/bin/catm libmescc.c \
 lib/mes/globals.c \
 lib/linux/x86_64-mes-mescc/syscall-internal.c
mescc libmescc.c
/usr/bin/cp libmescc.o /build/mes-0.27.1/lib/x86_64-mes/libmescc.a
/usr/bin/cp libmescc.s /build/mes-0.27.1/lib/x86_64-mes/libmescc.s

# libc.a
/usr/bin/catm libc.c \
 lib/ctype/isnumber.c \
 lib/mes/abtol.c \
 lib/mes/cast.c \
 lib/mes/eputc.c \
 lib/mes/fdgetc.c \
 lib/mes/fdputc.c \
