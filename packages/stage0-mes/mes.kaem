 lib/mes/utoa.c \
 lib/ctype/isdigit.c \
 lib/ctype/isspace.c \
 lib/ctype/isxdigit.c \
 lib/mes/assert_msg.c \
 lib/posix/write.c \
 lib/stdlib/atoi.c \
 lib/linux/lseek.c \
 lib/mes/__assert_fail.c \
 lib/mes/__buffered_read.c \
 lib/mes/__mes_debug.c \
