let { subsetOf, Attrs, BuildSpec, Local, Needs, OutputBin, OutputData, OutputLib, Source, .. } = import "minimal.ncl" in
let base = import "../base/build.ncl" in
let toolchain = import "../toolchain/build.ncl" in
let cmake = import "../cmake/build.ncl" in
let git = import "../git/build.ncl" in
let make = import "../make/build.ncl" in
let ninja = import "../ninja/build.ncl" in

let gcc = import "../gcc/build.ncl" in
let glibc = import "../glibc/build.ncl" in
let zlib = import "../zlib/build.ncl" in

let version = "9.15" in
{
  name = "or-tools",
  build_deps = [
    { file = "build.sh" } | Local,
    {
      url = "https://github.com/google/or-tools/archive/refs/tags/v%{version}.tar.gz",
      sha256 = "6395a00a97ff30af878ee8d7fd5ad0ab1c7844f7219182c6d71acbee1b5f3026",
      extract = true,
      strip_prefix = "or-tools-%{version}",
    } | Source,
    # ---- cmake FetchContent_Declare deps -----------------------------
    # Pre-staged here so build.sh can set FETCHCONTENT_SOURCE_DIR_<NAME>
    # to redirect each fetch to a local directory (cmake 3.24+ feature;
    # or-tools requires 3.24).
    #
    # Generated by `orch discover-cmake or-tools --remote` (2026-05-21).
    # cmake fetches NOT staged, disabled at cmake-configure time:
    #   - Eigen3 (gitlab)              -> -DBUILD_Eigen3=OFF
    #   - pybind11 (branch ref, py-only) -> not needed; BUILD_PYTHON=OFF
    # We also disable BUILD_ZLIB and use the system zlib build_dep below.
    #
    # BZip2: -DBUILD_BZip2=OFF does NOT disable it — BUILD_DEPS=ON FORCES
    # BUILD_BZip2 ON (or-tools README), so cmake/dependencies/CMakeLists.txt
    # FetchContent-clones gitlab.com/bzip2/bzip2.git @ "master" at configure
    # → fails offline. Pin master commit 66c46b8 (carries the CMakeLists the
    # 1.0.8 tag lacks); build.sh adds FETCHCONTENT_SOURCE_DIR_BZIP2 and
    # or-tools' patches/bzip2.patch applies to it (same as zlib's patch).
    {
      url = "https://github.com/madler/ZLIB/archive/refs/tags/v1.3.1.tar.gz",
      sha256 = "17e88863f3600672ab49182f217281b6fc4d3c762bde361935e436a95214d05c",
      extract = true,
    } | Source,
    {
      url = "https://gitlab.com/bzip2/bzip2/-/archive/66c46b8c9436613fd81bc5d03f63a61933a4dcc3/bzip2-66c46b8c9436613fd81bc5d03f63a61933a4dcc3.tar.gz",
      sha256 = "3a4cff5f9d197e9e6c6138660afa6b1f9370df0bed135bd949243f6dfc83b3e1",
      extract = true,
    } | Source,
    {
      url = "https://github.com/abseil/abseil-cpp/archive/refs/tags/20250814.1.tar.gz",
      sha256 = "1692f77d1739bacf3f94337188b78583cf09bab7e420d2dc6c5605a4f86785a1",
      extract = true,
    } | Source,
    {
      url = "https://github.com/protocolbuffers/protobuf/archive/refs/tags/v33.1.tar.gz",
      sha256 = "0c98bb704ceb4e68c92f93907951ca3c36130bc73f87264e8c0771a80362ac97",
      extract = true,
    } | Source,
    {
      url = "https://github.com/google/re2/archive/refs/tags/2025-08-12.tar.gz",
      sha256 = "2f3bec634c3e51ea1faf0d441e0a8718b73ef758d7020175ed7e352df3f6ae12",
      extract = true,
    } | Source,
    {
      url = "https://github.com/pybind/pybind11_abseil/archive/refs/tags/v202402.0.tar.gz",
      sha256 = "1496b112e86416e2dcf288569a3e7b64f3537f0b18132224f492266e9ff76c44",
      extract = true,
    } | Source,
    {
      url = "https://github.com/pybind/pybind11_protobuf/archive/f02a2b7653bc50eb5119d125842a3870db95d251.tar.gz",
      sha256 = "6c712ca5fc1e15df2ed1f55bd974c32a3065e658483616f3fda7607546db33ab",
      extract = true,
    } | Source,
    {
      url = "https://github.com/Mizux/GLPK/archive/refs/tags/5.0.1.tar.gz",
      sha256 = "d04c4f43512a1f162be75c9d1512e48ccd82d0c0ed6cc9c0052a9354a8515e65",
      extract = true,
    } | Source,
    {
      url = "https://github.com/ERGO-Code/HiGHS/archive/refs/tags/v1.12.0.tar.gz",
      sha256 = "cd0daddaca57e66b55524588d715dc62dcee06b5ab9ad186412dc23bc71ae342",
      extract = true,
    } | Source,
    {
      url = "https://github.com/boostorg/boost/archive/refs/tags/boost-1.87.0.tar.gz",
      sha256 = "c3ee7c763212db96a65dd5392b7ac0f2970f8e5567b0dcc12d8dc53ff8dbb770",
      extract = true,
    } | Source,
    {
      url = "https://github.com/scipopt/soplex/archive/refs/tags/v8.0.0.tar.gz",
      sha256 = "59828f88843ff5fd0adddbecf39a84c8a883b47dc26527bc4dedd2a4b98af07c",
      extract = true,
    } | Source,
    {
      url = "https://github.com/scipopt/scip/archive/refs/tags/v10.0.0.tar.gz",
      sha256 = "f750e1d94d4ee9382d3199430ea3c622d15b3e20032adafcfd89266b56d95c34",
      extract = true,
    } | Source,
    {
      url = "https://github.com/Mizux/CoinUtils/archive/refs/tags/cmake/2.11.12.tar.gz",
      sha256 = "ef42bac44ffd7d0be7939c0311479f86728bdfd3f40ce856ce4260b99087d10b",
      extract = true,
    } | Source,
    {
      url = "https://github.com/Mizux/Osi/archive/refs/tags/cmake/0.108.11.tar.gz",
      sha256 = "68ceebe5e997f6a6bfaec1714ae623470f21ed6850416e8126fe3b47c74c37f7",
      extract = true,
    } | Source,
    {
      url = "https://github.com/Mizux/Clp/archive/refs/tags/cmake/1.17.10.tar.gz",
      sha256 = "90c46e5bfc37ab87e41b535bafe7dbcb46bdc7a0f46148116479358de0c53eb5",
      extract = true,
    } | Source,
    {
      url = "https://github.com/Mizux/Cgl/archive/refs/tags/cmake/0.60.9.tar.gz",
      sha256 = "099df6d5d16171bea0964b6f460d8dadfe5aa5c5cf846cae378358b9b92d9816",
      extract = true,
    } | Source,
    {
      url = "https://github.com/Mizux/Cbc/archive/refs/tags/cmake/2.10.12.tar.gz",
      sha256 = "f7691eb28115a6c058f3a6d545b3834a9022d3a874a7c4b0e0698820f1cdb14a",
      extract = true,
    } | Source,
    {
      url = "https://github.com/google/googletest/archive/refs/tags/v1.17.0.tar.gz",
      sha256 = "65fab701d9829d38cb77c14acdc431d2108bfdbf8979e40eb8ae567edf10b27c",
      extract = true,
    } | Source,
    {
      url = "https://github.com/inazarenko/protobuf-matchers/archive/refs/tags/v0.1.1.tar.gz",
      sha256 = "0f4fec84ffc5a9122cf181e32779b5d9f715855224cb2bf369f70e39eb2213dd",
      extract = true,
    } | Source,
    {
      url = "https://github.com/google/benchmark/archive/refs/tags/v1.9.2.tar.gz",
      sha256 = "409075176168dc46bbb81b74c1b4b6900385b5d16bfc181d678afb060d928bd3",
      extract = true,
    } | Source,
    base,
    cmake,
    git,
    make,
    ninja,
    toolchain,
    zlib,
  ],
  runtime_deps = [
    glibc,
    subsetOf gcc ["libgcc", "libstdcpp"],
    zlib,
  ],

  # No internet needed: all 19 sha-pinned cmake submodules are
  # pre-staged via the Source build_deps above. BZip2 / Eigen3 / pybind11
  # are disabled at cmake-configure time (see build.sh).
  needs =
    {
      dns = {},
    } | Needs,

  cmd = "./build.sh",
  build_args = {
    include version,
  },

  outputs = {
    bins = { glob = "usr/bin/*" } | OutputBin,
    libortools = { glob = "usr/lib/libortools*.so*" } | OutputLib,
    libs = { glob = "usr/lib/lib*.so*" } | OutputLib,
    includes = { glob = "usr/include/**" } | OutputData,
    cmake_data = { glob = "usr/lib/cmake/**" } | OutputData,
    pkgconfigs = { glob = "usr/lib/pkgconfig/*.pc" } | OutputData,
  },

  attrs =
    {
      upstream_version = version,
      source_provenance = {
        category = 'GithubRepo,
        owner = "google",
        repo = "or-tools",
      },
      build_cost_multiple = 2,
    } | Attrs,
} | BuildSpec
